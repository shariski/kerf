# ── PostgreSQL (Docker local dev) ──────────────────────────────
# Copy this file to .env and fill in values before running the app.
# Never commit .env — only .env.example is committed.

POSTGRES_USER=kerf
POSTGRES_PASSWORD=kerf_dev
POSTGRES_DB=kerf_dev

# Full connection URL — must match the values above.
# Requires Docker container running: docker compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql://kerf:kerf_dev@localhost:5432/kerf_dev

# ── Auth (better-auth) ──────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret

# Base URL used by better-auth for redirect URLs and cookie domain
AUTH_URL=http://localhost:3000

# ── Social login (Google, GitHub) ── optional ──────────────────────────────
# Each provider is enabled only when both its CLIENT_ID and CLIENT_SECRET
# are set. Leave blank to disable a provider — the matching button on the
# login page will still render but signal an error if clicked.
#
# Google — https://console.cloud.google.com → APIs & Services → Credentials
#   → Create OAuth 2.0 Client ID (type: Web application)
#   Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
#   For production, also add: https://<your-domain>/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# GitHub — https://github.com/settings/developers → New OAuth App
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Email (Resend) ── Phase 4 only ─────────────────────────────────────────
# Not needed for local dev — magic links are logged to the server console.
# Sign up at https://resend.com and fill this in before production deploy.
# RESEND_API_KEY=re_xxxxxxxxxxxx
