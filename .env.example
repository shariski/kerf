# ── PostgreSQL (Docker local dev) ──────────────────────────────
# Copy this file to .env and fill in values before running the app.
# Never commit .env — only .env.example is committed.

POSTGRES_USER=kerf
POSTGRES_PASSWORD=kerf_dev
POSTGRES_DB=kerf_dev

# Full connection URL — must match the values above.
DATABASE_URL=postgresql://kerf:kerf_dev@localhost:5432/kerf_dev
