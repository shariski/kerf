{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "src/**/*.{ts,tsx,js,jsx}",
      "scripts/**/*.{ts,js}",
      "tests/**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/dist",
      "!**/build",
      "!**/.output",
      "!**/.tanstack"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": false
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": false
    }
  }
}
