# kerf — production environment template.
#
# Copy this file to `.env` on your deployment host and populate. NEVER
# commit `.env` (it contains secrets); only this `.example` file is
# tracked. The same `.env` is consumed by `docker-compose.prod.yml`
# (postgres + app services both read from it).
#
# Generate the random secrets with:
#   openssl rand -base64 32

# ── Postgres (compose service: `postgres`) ─────────────────────────────────
# These three are passed into the postgres container at first boot. The
# username/password/db combination is also inlined into DATABASE_URL
# below — change one, change the other.
POSTGRES_USER=kerf
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=kerf

# Connection URL the app uses to reach postgres. Hostname `postgres`
# resolves to the compose-managed service via the internal Docker
# network — DO NOT change to localhost (the app container has no
# postgres of its own).
DATABASE_URL=postgresql://kerf:replace_with_strong_password@postgres:5432/kerf

# ── Auth (better-auth) ─────────────────────────────────────────────────────
# Required in production — `src/server/env.ts` refuses to boot if any
# of AUTH_SECRET / AUTH_URL / DATABASE_URL is unset or empty.
AUTH_SECRET=replace_with_random_secret

# Public-facing base URL. Used for OAuth redirect URIs, magic-link
# emails, and cookie scoping. Must match what users type in the
# browser. HTTPS is required in production — better-auth flips
# `Secure` cookies on automatically when this starts with https://.
AUTH_URL=https://typekerf.com

# ── Social login (optional) ────────────────────────────────────────────────
# Each provider activates only when both its CLIENT_ID and CLIENT_SECRET
# are set. Before enabling, register the OAuth app with the provider
# pointing the redirect URI at:
#
#   https://typekerf.com/api/auth/callback/google
#   https://typekerf.com/api/auth/callback/github
#
# Leaving the env vars unset disables that button gracefully — the
# UI button still renders but signals an error if clicked.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Magic-link sender. Sign up at https://resend.com (free tier: 3,000
# emails / month) and verify your sending domain (SPF + DKIM TXT
# records) in the Resend dashboard before going live — until then,
# real sends are restricted to onboarding@resend.dev.
RESEND_API_KEY=replace_with_resend_api_key

# Friendly-name + sender address. Until your domain is verified,
# leave the fallback `onboarding@resend.dev`. After verification,
# swap to your branded sender (e.g. "kerf <hello@typekerf.com>") —
# no code change needed; src/server/email/send.ts reads this env var.
EMAIL_FROM=kerf <onboarding@resend.dev>

# Absolute URL of the kerf wordmark PNG used in magic-link emails.
# Gmail strips inline data: URIs as anti-phishing, so this must be
# publicly fetchable. If unset, the app derives it from AUTH_URL.
# EMAIL_LOGO_URL=https://typekerf.com/email-logo.png

# ── App-only ───────────────────────────────────────────────────────────────
# scripts/serve.mjs reads PORT (default 3000). The compose file binds
# the host's 127.0.0.1:3000 to the container's 3000 — your reverse
# proxy (Caddy/Nginx on the host) then proxies https://typekerf.com
# to 127.0.0.1:3000.
PORT=3000
